---
import i18next from "i18next";
const lang = i18next.language;
const titleLabel = lang === "es" ? "lenguaje" : "language";
---

<button class="switch" title={titleLabel}>
  <input id="language-toggle" class="check-toggle check-toggle-round-flat" type="checkbox" />
  <label for="language-toggle" />
  <span class="on">ES</span>
  <span class="off">EN</span>
</button>

<style>
:root {
  --bg: var(--naranja);
  --fg: var(--blanco);
}

.switch {
  position: fixed;
  top: 3rem;
  right: 8rem;
  display: inline-block;
  margin: 0 .5rem;
  appearance: none;
  border: none;
  outline: none;
  background: transparent;
  z-index: 2;
}

.switch > span {
  position: absolute;
  top: .9rem;
  pointer-events: none;
  font-family: var(--font-primary);
  font-weight: bold;
  font-size: 1.6rem;
  text-transform: uppercase;
  text-shadow: 0 1px 0 rgba(0, 0, 0, .06);
  width: 50%;
  text-align: center;
}

input.check-toggle-round-flat:checked ~ .off {
  color: var(--bg);
}

input.check-toggle-round-flat:checked ~ .on {
  color: var(--fg);
}

.switch > span.on {
  left: 0;
  padding-left: .4rem;
  color: var(--bg);
}

.switch > span.off {
  right: 0;
  padding-right: .4rem;
  color: var(--fg);
}

.check-toggle {
  position: absolute;
  margin-left: -9999px;
  visibility: hidden;
}

.check-toggle + label {
  display: block;
  position: relative;
  cursor: pointer;
  outline: none;
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
  user-select: none;
}

input.check-toggle-round-flat + label {
  padding: .2rem;
  width: 10rem;
  height: 3.5rem;
  background-color: var(--bg);
  -webkit-border-radius: 0;
  -moz-border-radius: 0;
  -ms-border-radius: 0;
  -o-border-radius: 0;
  border-radius: 0;
}

input.check-toggle-round-flat + label:before, input.check-toggle-round-flat + label:after {
  display: block;
  position: absolute;
  content: "";
}

input.check-toggle-round-flat + label:before {
  top: .2rem;
  left: .2rem;
  bottom: .2rem;
  right: .2rem;
  background-color: var(--bg);
  -moz-border-radius: 0;
  -ms-border-radius: 0;
  -o-border-radius: 0;
  border-radius: 0;
}

input.check-toggle-round-flat + label:after {
  top: .4rem;
  left: .4rem;
  bottom: .4rem;
  width: 4.8rem;
  background-color: var(--fg);
  -webkit-border-radius: 0;
  -moz-border-radius: 0;
  -ms-border-radius: 0;
  -o-border-radius: 0;
  border-radius: 0;
  -webkit-transition: margin 0.2s;
  -moz-transition: margin 0.2s;
  -o-transition: margin 0.2s;
  transition: margin 0.2s;
}

input.check-toggle-round-flat:checked + label:after {
  margin-left: 4.4rem;
} 

@media (max-width: 768px) {
  :root {
    --bg: var(--negro);
    --fg: var(--blanco);
  }

  .switch {
    position: relative;
    transform: translateY(-1000%);
    opacity: 0;
    transition: all 0.3s ease;
  }

  :global(:has(.burger-active)) .switch {
    opacity: 1;
    filter: grayscale(1);
    transform: translateY(0);
    top: 0;
    left: 0;
    right: 0;
    z-index: 3;
  }
}
</style>

<script>
  const lang = window.location.pathname.includes('/en')
  const toggle = document.getElementById('language-toggle')

  !lang ? toggle.checked = false : toggle.checked = true;

  window.addEventListener('DOMContentLoaded', () => {
    toggle.addEventListener('change', () => {
      const isEnglish = toggle.checked
      setTimeout(() => {
        isEnglish ? window.location.href = '/en' : window.location.href = '/'
      }, 200)
    })
  })
</script>
